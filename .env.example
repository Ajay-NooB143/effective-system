BINANCE_API_KEY=your_binance_api_key_here
BINANCE_SECRET=your_binance_secret_here
TELEGRAM_TOKEN=your_telegram_bot_token_here
CHAT_ID=your_telegram_chat_id_here
OPENAI_API_KEY=your_openai_api_key_here
MODE=SAFE
PORT=5000
WEBHOOK_SECRET=your_webhook_secret_here
ORDER_QTY=0.001

# ── Python trading pipeline ──────────────────────────────────────────────────

# Telegram
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_CHAT_ID=your_telegram_chat_id_here

# Flask webhook port (default: 5001)
FLASK_PORT=5001

# Trading mode: "sim" (default, safe) or "live" (real Binance orders)
TRADING_MODE=sim

# Risk limits
MAX_DAILY_LOSS=0.05      # 5 % of portfolio per day
MAX_DRAWDOWN=0.10        # 10 % max drawdown
MAX_POSITION_PCT=0.20    # 20 % max single-position size
ALERT_POSITION_PCT=0.10  # notional size per webhook alert (10 % of balance)

# Portfolio
PORTFOLIO_SYMBOLS=BTCUSDT,ETHUSDT,XAUUSD,EURUSD
INITIAL_BALANCE=10000

# Model paths
XGBOOST_MODEL_PATH=models/xgboost_model.pkl
TRANSFORMER_MODEL_PATH=models/transformer_model.pt
QTABLE_PATH=models/qtable.pkl
PPO_MODEL_PATH=models/ppo_model

# Retrain schedule (days between runs, default: 7)
RETRAIN_INTERVAL_DAYS=7
